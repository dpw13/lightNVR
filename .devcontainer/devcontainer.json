{
  "name": "Dev Container with Build Tools and Node",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "forwardPorts": [],
  "postCreateCommand": "npm install",
  "remoteUser": "root"
}